{
  "name": "cashfb-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "dev:worker": "tsx watch --env-file-if-exists=.env src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --max-warnings=0",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed": "tsx scripts/seed.ts",
    "admin:create": "tsx scripts/admin-create.ts",
    "migrate:plans": "tsx scripts/migrate-razorpay-plans.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1034.0",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/client-ses": "^3.1035.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.1",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dayjs": "^1.11.20",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lru-cache": "^11.3.5",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pino": "^9.5.0",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.6",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "mongodb-memory-server": "^11.0.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "mongodb-memory-server"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
