{
  "info": {
    "name": "CashFB Admin",
    "description": "Admin surface for the CashFB backend (Phase 8 Chunks 1–4). Import the companion environment (`CashFB-Admin.postman_environment.json`) and run the `_setup > Login` request first — its test script captures the session cookie + CSRF token into env variables that the pre-request script below injects into every subsequent request.\n\n57 endpoints across 7 folders. Every folder mirrors a route mount in `src/app.ts`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "noauth" },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Inject X-CSRF-Token on every state-changing method.",
          "const method = pm.request.method.toUpperCase();",
          "if (['POST', 'PATCH', 'PUT', 'DELETE'].includes(method)) {",
          "  const csrf = pm.environment.get('csrfToken');",
          "  if (csrf) pm.request.headers.add({ key: 'X-CSRF-Token', value: csrf });",
          "}"
        ]
      }
    }
  ],
  "variable": [{ "key": "baseUrl", "value": "{{baseUrl}}" }],
  "item": [
    {
      "name": "_setup",
      "item": [
        {
          "name": "Login (captures cookies + csrfToken)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Validate the login envelope before writing env vars.",
                  "// Throw with a human-readable reason so operators see",
                  "// 'Login failed: ...' in Postman's test tab rather than",
                  "// diagnosing downstream 401s.",
                  "const res = pm.response.json();",
                  "if (!res.success || !res.data || !res.data.csrfToken) {",
                  "  throw new Error('Login failed: ' + JSON.stringify(res.error));",
                  "}",
                  "pm.environment.set('csrfToken', res.data.csrfToken);",
                  "// Session cookie auto-captured by Postman's cookie jar;",
                  "// the jar replays it on subsequent requests.",
                  "pm.test('Login returned admin object', () => {",
                  "  pm.expect(res.data.admin).to.have.property('role');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "auth", "logout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.environment.unset('csrfToken');"]
              }
            }
          ]
        }
      ]
    },
