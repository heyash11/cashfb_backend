# Ensure nvm-managed Node + pnpm resolve when git is invoked from
# GUI clients (Fork, GitHub Desktop, VSCode source control) or a
# shell that defaults to a different Node version.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  \. "$NVM_DIR/nvm.sh" >/dev/null
  nvm use --silent >/dev/null 2>&1 || true
fi

pnpm typecheck
pnpm exec lint-staged
